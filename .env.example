# Copy to .env (gitignored) or run: pnpm cli config --project <id> --zone <zone>
GCP_PROJECT_ID=your-gcp-project-id
# Default zone for new servers; `list` finds existing servers in any zone.
GCP_ZONE=us-central1-a
# Optional overrides:
# GCP_SOURCE_IMAGE=projects/debian-cloud/global/images/family/debian-12
# GCP_NETWORK_TAG=onehost
# Snapshots kept per server after each stop (default 3; <= 0 keeps all):
# ONEHOST_SNAPSHOT_KEEP=3
# Reconcile sweep (worker on Cloud Scheduler's cron; also `cli sweep`):
#   warn once a RUNNING server is up this many hours (0 = sweep off):
# ONEHOST_MAX_UPTIME_HOURS=8
#   also auto-stop once up this many hours (0 / below max = warn only):
# ONEHOST_AUTOSTOP_UPTIME_HOURS=24

# --- Discord bot (apps/interactions + apps/worker) ---
# In production these come from Cloud Run env (Terraform sets them). For local
# dev, set them here. None are real secrets except DISCORD_BOT_TOKEN, which is
# only used by the one-off `register` script — never at runtime.
# DISCORD_APPLICATION_ID=your-app-id
# DISCORD_PUBLIC_KEY=your-app-public-key      # interactions: verify signatures
# DISCORD_CHANNEL_ID=channel-id               # interactions: only accept this channel
# DISCORD_CHANNEL_WEBHOOK_URL=                # worker: announce tokenless jobs (idle teardown) here
# DISCORD_BOT_TOKEN=your-bot-token            # register script only
# DISCORD_GUILD_ID=your-guild-id              # register script only
#
# Job transport between interactions and worker:
#   pubsub (default, prod) — needs PUBSUB_TOPIC (default "onehost-jobs")
#   http   (local dev)     — interactions posts straight at the worker
# JOB_TRANSPORT=http
# WORKER_URL=http://localhost:8081            # when JOB_TRANSPORT=http
# PUBSUB_TOPIC=onehost-jobs
# PUBSUB_PUSH_TOKEN=                          # worker: optional ?token= shared secret
