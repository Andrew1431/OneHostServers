# Copy to .env (gitignored) or run: pnpm cli config --project <id> --zone <zone>
# This file is for CLI usage. App/worker config lives in infra/terraform.tfvars
# (Cloud Run env) — there's no reason to run the control plane locally.

# --- Required ---
GCP_PROJECT_ID=your-gcp-project-id
# Default zone for new servers; `list` finds existing servers in any zone.
GCP_ZONE=us-central1-a

# --- Optional CLI overrides ---
# GCP_SOURCE_IMAGE=projects/debian-cloud/global/images/family/debian-12
# GCP_NETWORK_TAG=onehost
# GCP_GAME_VM_SA=onehost-vm@your-project.iam.gserviceaccount.com
# ONEHOST_SNAPSHOT_KEEP=3                # snapshots kept per server (<= 0 keeps all)
# DUCKDNS_TOKEN=your-duckdns-token       # needed for `cli dns` to publish (DuckDNS)

# --- `pnpm register` only (one-off Discord slash-command registration) ---
# Not used at runtime; the deployed bot reads its config from Terraform.
# DISCORD_APPLICATION_ID=your-app-id
# DISCORD_BOT_TOKEN=your-bot-token
# DISCORD_GUILD_ID=your-guild-id
