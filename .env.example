# Copy to .env (gitignored) or run: pnpm cli config --project <id> --zone <zone>
GCP_PROJECT_ID=your-gcp-project-id
# Default zone for new servers; `list` finds existing servers in any zone.
GCP_ZONE=us-central1-a
# Optional overrides:
# GCP_SOURCE_IMAGE=projects/debian-cloud/global/images/family/debian-12
# GCP_NETWORK_TAG=onehost
# Snapshots kept per server after each stop (default 3; <= 0 keeps all):
# ONEHOST_SNAPSHOT_KEEP=3
